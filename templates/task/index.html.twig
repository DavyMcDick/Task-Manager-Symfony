{% extends 'base.html.twig' %}

{% block title %}Task Manager{% endblock %}

{% block body %}
    <main class="mx-auto min-h-screen max-w-7xl px-4 pb-10 pt-8 sm:px-6 lg:px-8">
        <section class="rounded-[2rem] border border-slate-200/80 bg-white/90 p-6 shadow-soft sm:p-8">
            <div class="flex flex-col gap-8">
                <div class="pointer-events-none fixed right-4 top-4 z-[60] flex w-full max-w-sm flex-col gap-3 sm:right-6 sm:top-6" data-toast-region></div>

                <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
                    <div class="max-w-2xl">
                        <div class="flex items-start justify-between gap-3">
                            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-700">Task Manager</p>
                        </div>
                        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Simple work, clear progress.</h1>
                        <p class="mt-4 text-base leading-7 text-slate-600">
                            A clean dashboard to add, update, and complete tasks without leaving the page.
                        </p>
                    </div>

                    <div class="self-start lg:self-start">
                        <div class="inline-flex items-center gap-1 rounded-2xl border border-slate-200 bg-white p-1 shadow-sm" aria-label="Switch task layout">
                            <button
                                type="button"
                                class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-900 shadow-sm transition"
                                data-layout-button
                                data-layout-target="list"
                                aria-label="List view"
                                title="List view"
                            >
                                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                                    <path d="M6 7h12"/>
                                    <path d="M6 12h12"/>
                                    <path d="M6 17h12"/>
                                </svg>
                            </button>
                            <button
                                type="button"
                                class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-transparent bg-transparent text-slate-500 transition"
                                data-layout-button
                                data-layout-target="board"
                                aria-label="Board view"
                                title="Board view"
                            >
                                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                                    <rect x="4" y="5" width="5" height="14" rx="1.5"/>
                                    <rect x="10" y="5" width="5" height="14" rx="1.5"/>
                                    <rect x="16" y="5" width="4" height="14" rx="1.5"/>
                                </svg>
                            </button>
                        </div>

                        <div class="mt-3">
                            <button
                                type="button"
                                class="inline-flex items-center justify-center rounded-full bg-cyan-500 px-5 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-cyan-600 focus:outline-none focus:ring-4 focus:ring-cyan-200"
                                aria-label="Add task"
                                title="Add task"
                                data-open-create-modal
                            >
                                Add Task
                            </button>
                        </div>
                    </div>
                </div>

                <div class="hidden" data-flash-messages>
                    {% for message in app.flashes('task_created') %}
                        <p data-flash-message data-flash-variant="create">{{ message }}</p>
                    {% endfor %}
                    {% for message in app.flashes('task_updated') %}
                        <p data-flash-message data-flash-variant="update">{{ message }}</p>
                    {% endfor %}
                    {% for message in app.flashes('task_deleted') %}
                        <p data-flash-message data-flash-variant="delete">{{ message }}</p>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <p data-flash-message data-flash-variant="error">{{ message }}</p>
                    {% endfor %}
                </div>

                {% if loadMeta.hasMore %}
                    <div class="rounded-2xl border border-cyan-200 bg-cyan-50/80 px-4 py-3 text-sm font-medium text-cyan-800">
                        Showing {{ loadMeta.visible }} of {{ loadMeta.total }} tasks. Use pagination or increase the limit parameter to load more.
                    </div>
                {% endif %}

                <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-soft transition duration-200" data-layout-panel="list">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200" data-task-table data-reorder-url="{{ path('task_reorder') }}" data-create-url="{{ path('task_create_ajax') }}" data-update-url-template="{{ path('task_update_ajax', {'id': 0}) }}" data-create-token="{{ csrf_token('task-create') }}">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Move</th>
                                    <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Title</th>
                                    <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Description</th>
                                    <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Status</th>
                                    <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Created</th>
                                    <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 bg-white" data-task-table-body>
                                {% for task in tasks %}
                                    <tr
                                        class="align-top transition hover:bg-slate-50"
                                        data-task-row
                                        data-task-id="{{ task.id }}"
                                        data-task-title="{{ task.title|e('html_attr') }}"
                                        data-task-description="{{ (task.description ?? '')|e('html_attr') }}"
                                        data-task-status="{{ task.status.value }}"
                                        data-task-due-date="{{ task.dueDate ? task.dueDate|date('Y-m-d') : '' }}"
                                    >
                                        <td class="px-6 py-5">
                                            <div class="inline-flex cursor-grab items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 p-3 text-slate-400 active:cursor-grabbing" data-list-drag-handle>
                                                <span class="select-none text-lg leading-none">::</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-5">
                                            <div class="text-base font-semibold text-slate-900">{{ task.title }}</div>
                                        </td>
                                        <td class="px-6 py-5">
                                            <div class="max-w-md text-sm leading-6 text-slate-600">
                                                {{ task.description ?: 'No description provided.' }}
                                            </div>
                                        </td>
                                        <td class="px-6 py-5">
                                            <div class="space-y-3">
                                                <span
                                                    class="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.15em] ring-1 ring-inset {{ task.status.badgeClasses }}"
                                                    data-status-badge
                                                >
                                                    {{ task.status.label }}
                                                </span>
                                                <p class="max-w-56 text-xs leading-5 text-slate-500" data-status-help>
                                                    {{ task.status.helpText }}
                                                </p>
                                                <form method="post" action="{{ path('task_update_status', {'id': task.id}) }}" class="flex items-center gap-2" data-status-form data-task-id="{{ task.id }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('update-status-' ~ task.id) }}">
                                                    <select
                                                        name="status"
                                                        class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm transition focus:border-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-200"
                                                        data-status-select
                                                        aria-label="Update task status"
                                                    >
                                                        {% for status in statuses %}
                                                            <option value="{{ status.value }}" {% if task.status == status %}selected{% endif %}>{{ status.label }}</option>
                                                        {% endfor %}
                                                    </select>
                                                </form>
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 text-sm text-slate-600">
                                            <span class="whitespace-nowrap">{{ task.createdAt|date('M d, Y - H:i', 'Asia/Manila') }}</span>
                                        </td>
                                        <td class="px-6 py-5">
                                            <div class="flex flex-col items-stretch gap-3 sm:flex-row sm:justify-end">
                                                <button
                                                    type="button"
                                                    class="inline-flex items-center justify-center rounded-full border border-cyan-200 bg-cyan-50 px-4 py-2 text-sm font-semibold text-cyan-700 transition hover:border-cyan-300 hover:bg-cyan-100"
                                                    data-open-edit-modal
                                                    data-task-id="{{ task.id }}"
                                                    data-task-token="{{ csrf_token('task-edit-' ~ task.id) }}"
                                                >
                                                    Edit
                                                </button>
                                                <form method="post" action="{{ path('task_delete', {'id': task.id}) }}" data-delete-task-form data-task-id="{{ task.id }}" data-task-title="{{ task.title|e('html_attr') }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-task-' ~ task.id) }}">
                                                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-full border border-rose-200 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:border-rose-300 hover:bg-rose-100">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="px-6 py-12 text-center" data-list-empty-row>
                                            <div class="mx-auto max-w-md">
                                                <p class="text-lg font-semibold text-slate-900">No tasks yet</p>
                                                <p class="mt-2 text-sm leading-6 text-slate-600">Create your first task to start tracking work, progress, and completed items.</p>
                                                <button type="button" class="mt-6 inline-flex items-center justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" data-open-create-modal>
                                                    Create First Task
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <section class="hidden rounded-[1.75rem] border border-slate-200 bg-white p-4 shadow-soft transition duration-200" data-layout-panel="board">
                    <div class="grid gap-4 xl:grid-cols-3">
                        {% for status in statuses %}
                            <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/60 p-4">
                                <div class="flex items-center justify-between gap-3">
                                    <div class="flex items-center gap-3">
                                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.15em] ring-1 ring-inset {{ status.badgeClasses }}">
                                            {{ status.label }}
                                        </span>
                                        <span class="text-sm font-semibold text-slate-500" data-board-count>{{ boardTasks[status.value]|length }}</span>
                                    </div>
                                </div>
                                <p class="mt-3 text-sm text-slate-500">{{ status.helpText }}</p>

                                <div class="mt-4 space-y-4" data-board-column="{{ status.value }}">
                                    {% for task in boardTasks[status.value] %}
                                        <article
                                            class="rounded-[1.4rem] border border-slate-200 bg-white p-4 shadow-sm transition duration-150 hover:border-cyan-200"
                                            data-task-card
                                            data-task-id="{{ task.id }}"
                                            data-task-title="{{ task.title|e('html_attr') }}"
                                            data-task-description="{{ (task.description ?? '')|e('html_attr') }}"
                                            data-task-status="{{ task.status.value }}"
                                            data-task-due-date="{{ task.dueDate ? task.dueDate|date('Y-m-d') : '' }}"
                                        >
                                            <div class="flex items-start justify-between gap-3">
                                                <div class="min-w-0">
                                                    <p class="text-base font-bold text-slate-900">{{ task.title }}</p>
                                                    <p class="mt-2 text-sm leading-6 text-slate-600">
                                                        {{ task.description ?: 'No description provided.' }}
                                                    </p>
                                                </div>
                                                <div class="flex shrink-0 items-center gap-2">
                                                    <button
                                                        type="button"
                                                        class="inline-flex items-center justify-center rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1.5 text-xs font-semibold text-cyan-700 transition hover:border-cyan-300 hover:bg-cyan-100"
                                                        data-open-edit-modal
                                                        data-task-id="{{ task.id }}"
                                                        data-task-token="{{ csrf_token('task-edit-' ~ task.id) }}"
                                                    >
                                                        Edit
                                                    </button>
                                                    <form method="post" action="{{ path('task_delete', {'id': task.id}) }}" data-delete-task-form data-task-id="{{ task.id }}" data-task-title="{{ task.title|e('html_attr') }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-task-' ~ task.id) }}">
                                                        <button type="submit" class="text-xs font-semibold text-slate-400 transition hover:text-rose-600" aria-label="Delete task" title="Delete task">
                                                            Delete
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>

                                            <div class="mt-4 flex items-center justify-between gap-3">
                                                <span
                                                    class="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.15em] ring-1 ring-inset {{ task.status.badgeClasses }}"
                                                    data-status-badge
                                                >
                                                    {{ task.status.label }}
                                                </span>
                                                <span class="whitespace-nowrap text-xs font-medium text-slate-500">{{ task.createdAt|date('M d, Y - H:i', 'Asia/Manila') }}</span>
                                            </div>

                                            <p class="mt-3 text-xs leading-5 text-slate-500" data-status-help>{{ task.status.helpText }}</p>

                                            <form method="post" action="{{ path('task_update_status', {'id': task.id}) }}" class="mt-4" data-status-form data-task-id="{{ task.id }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('update-status-' ~ task.id) }}">
                                                <select
                                                    name="status"
                                                    class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm transition focus:border-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-200"
                                                    data-status-select
                                                    aria-label="Update task status"
                                                >
                                                    {% for option in statuses %}
                                                        <option value="{{ option.value }}" {% if task.status == option %}selected{% endif %}>{{ option.label }}</option>
                                                    {% endfor %}
                                                </select>
                                            </form>
                                        </article>
                                    {% else %}
                                        <div class="rounded-[1.3rem] border border-dashed border-slate-300 bg-white/70 px-4 py-6 text-center" data-board-empty>
                                            <p class="text-sm font-semibold text-slate-700">No tasks here</p>
                                            <p class="mt-1 text-xs text-slate-500">Move a task into {{ status.label|lower }} to fill this column.</p>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </section>

                <div class="fixed inset-0 z-[70] hidden items-center justify-center p-4" data-delete-modal aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title">
                    <div class="absolute inset-0 bg-slate-900/35 opacity-0 transition duration-200" data-delete-modal-backdrop></div>
                    <div class="relative w-full max-w-md rounded-3xl bg-white p-6 shadow-2xl shadow-slate-950/20 opacity-0 scale-95 transition duration-200" data-delete-modal-panel>
                        <h2 id="delete-modal-title" class="text-xl font-bold tracking-tight text-slate-900">Delete task?</h2>
                        <p class="mt-2 text-sm leading-6 text-slate-600">This action cannot be undone.</p>
                        <p class="mt-2 text-sm font-semibold text-slate-800" data-delete-modal-task></p>
                        <div class="mt-6 flex items-center justify-end gap-3">
                            <button type="button" class="inline-flex items-center justify-center rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100" data-delete-modal-cancel>
                                Cancel
                            </button>
                            <button type="button" class="inline-flex items-center justify-center rounded-full bg-cyan-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-700" data-delete-modal-confirm>
                                Delete
                            </button>
                        </div>
                    </div>
                </div>

                <div class="fixed inset-0 z-[75] hidden items-center justify-center p-4" data-task-modal aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="task-modal-title">
                    <div class="absolute inset-0 bg-slate-900/35 opacity-0 transition duration-200" data-task-modal-backdrop></div>
                    <div class="relative w-full max-w-xl rounded-3xl bg-white p-6 shadow-2xl shadow-slate-950/20 opacity-0 scale-95 transition duration-200 sm:p-8" data-task-modal-panel>
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-700" data-task-modal-kicker>New Task</p>
                                <h2 id="task-modal-title" class="mt-2 text-2xl font-bold tracking-tight text-slate-900" data-task-modal-title>Add Task</h2>
                                <p class="mt-2 text-sm text-slate-600">Capture key details with a lightweight form.</p>
                            </div>
                            <button type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-full text-slate-500 transition hover:bg-slate-100" data-task-modal-close aria-label="Close task modal">
                                <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                    <path d="M6 6l12 12"/>
                                    <path d="M18 6l-12 12"/>
                                </svg>
                            </button>
                        </div>

                        <form class="mt-6 space-y-5" data-task-modal-form>
                            <input type="hidden" name="mode" value="create" data-task-modal-mode>
                            <input type="hidden" name="taskId" value="" data-task-modal-task-id>
                            <input type="hidden" name="_token" value="{{ csrf_token('task-create') }}" data-task-modal-token>

                            <div class="relative">
                                <input id="task-modal-title-input" name="title" type="text" placeholder=" " class="peer block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 pb-3 pt-6 text-sm font-medium text-slate-900 transition focus:border-cyan-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-cyan-200" data-task-modal-input-title>
                                <label for="task-modal-title-input" class="pointer-events-none absolute left-4 top-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500 transition peer-focus:text-cyan-700">Title</label>
                                <p class="mt-2 text-xs font-medium text-rose-600" data-task-modal-error="title"></p>
                            </div>

                            <div class="relative">
                                <textarea id="task-modal-description-input" name="description" rows="4" placeholder=" " class="peer block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 pb-3 pt-6 text-sm text-slate-900 transition focus:border-cyan-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-cyan-200" data-task-modal-input-description></textarea>
                                <label for="task-modal-description-input" class="pointer-events-none absolute left-4 top-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500 transition peer-focus:text-cyan-700">Description</label>
                                <p class="mt-2 text-xs font-medium text-rose-600" data-task-modal-error="description"></p>
                            </div>

                            <div class="grid gap-4 sm:grid-cols-2">
                                <div>
                                    <label for="task-modal-status-input" class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Status</label>
                                    <select id="task-modal-status-input" name="status" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 transition focus:border-cyan-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-cyan-200" data-task-modal-input-status>
                                        {% for status in statuses %}
                                            <option value="{{ status.value }}">{{ status.label }}</option>
                                        {% endfor %}
                                    </select>
                                    <p class="mt-2 text-xs font-medium text-rose-600" data-task-modal-error="status"></p>
                                </div>
                                <div>
                                    <label for="task-modal-due-date-input" class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Due Date</label>
                                    <input id="task-modal-due-date-input" name="dueDate" type="date" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 transition focus:border-cyan-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-cyan-200" data-task-modal-input-due-date>
                                    <p class="mt-2 text-xs font-medium text-rose-600" data-task-modal-error="dueDate"></p>
                                </div>
                            </div>

                            <p class="text-xs font-medium text-rose-600" data-task-modal-error="form"></p>

                            <div class="flex items-center justify-end gap-3 pt-2">
                                <button type="button" class="inline-flex items-center justify-center rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100" data-task-modal-cancel>
                                    Cancel
                                </button>
                                <button type="submit" class="inline-flex items-center justify-center rounded-full bg-cyan-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-cyan-700" data-task-modal-submit>
                                    Save Task
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </section>
    </main>
{% endblock %}
